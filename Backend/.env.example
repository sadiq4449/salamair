# Local: copy to .env. Railway: set variables in the service (do not paste secrets in git).
# Railway Postgres often needs SSL — use the DATABASE_URL from the Postgres plugin, e.g.:
# postgresql://user:pass@host:port/railway?sslmode=require
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/salamair
SECRET_KEY=change-this-to-a-random-secret-key
# Include your public app URL so the browser can call the API (same origin when using Dockerfile SPA).
# Railway example: CORS_ORIGINS=https://your-service.up.railway.app
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
ENVIRONMENT=development

# Email Configuration (Gmail: use App Password, enable 2FA)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=sadiqcds22@gmail.com
SMTP_FROM_NAME=Salam Air Sales
SMTP_USE_TLS=true
# If connection "times out" on port 587, try: SMTP_IMPLICIT_SSL=true and SMTP_PORT=465
SMTP_IMPLICIT_SSL=false
SMTP_TIMEOUT_SECONDS=75
# Outbound path: by default, if RESEND_API_KEY is set it wins over SMTP. Set SMTP_PREFERRED=true to always use SMTP
# (and remove or leave RESEND_API_KEY empty). Many Render/Railway free tiers block SMTP — if sends time out, use Resend.
# SMTP_PREFERRED=false
# Railway Free/Hobby and many Render tiers block outbound SMTP (465/587). Use Resend (HTTPS) — key from resend.com.
# When RESEND_API_KEY is set and SMTP_PREFERRED is false, SMTP is skipped in favor of Resend.
# Gmail/Yahoo/etc. cannot be the Resend "From" — the app uses onboarding@resend.dev + Reply-To your SMTP_FROM_EMAIL.
# With that test sender, Resend only delivers to your Resend account email until you verify a domain.
# For production (any recipient), verify a domain at resend.com and set RESEND_FROM_EMAIL=noreply@yourdomain.com
# RESEND_API_KEY=
# RESEND_FROM_EMAIL=
# Optional: set false to force SMTP off even when SMTP_USER/PASSWORD exist.
# Omit or leave unset to auto-enable sending when SMTP_USER and SMTP_PASSWORD are set.
# EMAIL_ENABLED=
RM_DEFAULT_EMAIL=sadiqcds22@gmail.com

# Inbound: IMAP poll for RM replies (same Google account: enable IMAP in Gmail settings).
# Omit IMAP_ENABLED to auto-enable when IMAP_USER and IMAP_PASSWORD are set.
# IMAP_ENABLED=
IMAP_HOST=imap.gmail.com
IMAP_PORT=993
IMAP_USE_SSL=true
IMAP_USER=
IMAP_PASSWORD=
IMAP_MAILBOX=INBOX
# Optional: cron / automation calls POST /api/v1/email/poll-inbox with header X-Email-Poll-Secret
EMAIL_POLL_SECRET=

# Analytics (optional): Redis improves shared cache across workers; if unset, in-process TTL cache is used.
# REDIS_URL=
# ANALYTICS_CACHE_TTL_SECONDS=600

# Groq API (optional): powers POST /api/v1/ai/pricing-assistant. Get a key at https://console.groq.com/
# GROQ_API_KEY=
# GROQ_MODEL=llama-3.3-70b-versatile

# Gmail API (optional): sales ↔ agent email thread only — RM email stays on SMTP/IMAP.
# Google Cloud Console → APIs & Services → OAuth 2.0 Client ID (Web). Enable Gmail API.
# Authorized redirect URI must match GOOGLE_OAUTH_REDIRECT_URI exactly (backend callback URL).
# GOOGLE_OAUTH_CLIENT_ID=
# GOOGLE_OAUTH_CLIENT_SECRET=
# GOOGLE_OAUTH_REDIRECT_URI=http://127.0.0.1:8000/api/v1/integrations/gmail/callback
# Where the browser lands after OAuth (SPA). Add ?gmail_connected=1 is appended by the API.
# GOOGLE_OAUTH_SUCCESS_REDIRECT=http://localhost:5173/
# Optional: one refresh token so sales↔agent thread uses Gmail API without each user clicking Connect.
# Same OAuth client as above; obtain once (local OAuth or Google OAuth Playground). RM email stays SMTP.
# GMAIL_AGENT_THREAD_REFRESH_TOKEN=
